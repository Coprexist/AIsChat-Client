{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "AIsChat",
  "identifier": "com.coprexist.aischatclient",
  "version": "0.1.0",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "https://aischat.datongai.top/",
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self' https://aischat.datongai.top; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://aischat.datongai.top; style-src 'self' 'unsafe-inline' https://aischat.datongai.top; img-src 'self' data: blob: https://aischat.datongai.top; connect-src 'self' https://aischat.datongai.top https://tauri.localhost http://tauri.localhost; font-src 'self' https://aischat.datongai.top",
      "capabilities": [
        {
          "identifier": "main-default",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "minimumSystemVersion": "14.0"
    },
    "windows": {
      "nsis": null,
      "wix": null
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {},
      "rpm": {}
    }
  }
}
